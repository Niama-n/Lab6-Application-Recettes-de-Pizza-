<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pizza_red"
    android:orientation="vertical"
    android:gravity="center_horizontal">

    <!-- Image pizza au centre haut -->
    <ImageView
        android:id="@+id/imgSplash"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@mipmap/pizza1"
        android:layout_marginTop="120dp"
        android:scaleType="centerInside"
        android:contentDescription="@string/splash_image_desc"/>

    <!-- Titre : Recettes Pizza -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🍕 Recettes Pizza 🍕"
        android:textColor="@android:color/white"
        android:textSize="28sp"
        android:textStyle="bold|italic"
        android:layout_marginTop="30dp"
        android:gravity="center"/>

    <!-- Sous-titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="😄 You can\'t make everyone happy.\nYou\'re not pizza. 🍕"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:textStyle="italic"
        android:layout_marginTop="8dp"
        android:gravity="center"/>

    <!-- Loading spinner -->
    <ProgressBar
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="60dp"
        android:indeterminate="true"
        android:indeterminateTint="@android:color/holo_blue_light"/>

</LinearLayout>